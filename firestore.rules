rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null && request.auth.token.email != null;
    }

    function actorPath() {
      return /databases/$(database)/documents/allowedUsers/$(request.auth.token.email);
    }

    function isAllowed() {
      return isSignedIn() && exists(actorPath());
    }

    function actorRole() {
      return isAllowed() ? get(actorPath()).data.role : null;
    }

    function isAdmin() {
      return actorRole() == "admin";
    }

    function isStaff() {
      return actorRole() == "staff";
    }

    function isAllowedRole() {
      return isAdmin() || isStaff();
    }

    function isValidVehicleType(value) {
      return value == "car" || value == "motorcycle" || value == "both";
    }

    function hasOnlyOverrideFields() {
      return request.resource.data.keys().hasOnly([
        "name",
        "vehicleType",
        "active",
        "origin",
        "source",
        "createdAt",
        "createdBy",
        "updatedAt",
        "updatedBy",
      ]);
    }

    function isOwnerCreated() {
      return isAllowed() && resource.data.createdBy == request.auth.token.email;
    }

    function preservesCreatedBy() {
      return !("createdBy" in request.resource.data) || request.resource.data.createdBy == resource.data.createdBy;
    }

    match /allowedUsers/{email} {
      allow read: if isSignedIn();
      allow create, update, delete: if isAdmin();
    }

    match /clients/{clientId} {
      allow read: if isAllowedRole();
      allow create, update, delete: if isAdmin();
    }

    match /cars/{carId} {
      allow read: if isAllowedRole();
      allow create: if isAllowedRole();
      allow update: if isAdmin() || (isStaff() && isOwnerCreated() && preservesCreatedBy());
      allow delete: if isAdmin();
    }

    match /appointments/{appointmentId} {
      allow read: if isAllowedRole();
      allow create: if isAllowedRole() && request.resource.data.createdBy == request.auth.token.email;
      allow update: if isAdmin()
        || (isStaff()
          && isOwnerCreated()
          && preservesCreatedBy()
          && request.resource.data.deleted == resource.data.deleted);
      allow delete: if false; // soft delete only
    }

    match /jobTypes/{id} {
      allow read: if isAllowedRole();
      allow create, update, delete: if isAdmin();
    }

    match /vehicleMakes/{id} {
      allow read: if isAllowedRole();
      allow create, update, delete: if isAdmin();
    }

    match /vehicleModels/{id} {
      allow read: if isAllowedRole();
      allow create, update, delete: if isAdmin();
    }

    // Admin UI overrides: write allowed only to admins.
    match /vehicleMakeOverrides/{id} {
      allow read: if isAllowedRole();
      allow create: if isAdmin()
        && hasOnlyOverrideFields()
        && request.resource.data.name is string
        && request.resource.data.name.size() > 0
        && request.resource.data.active is bool
        && request.resource.data.origin in ["custom", "baseline"]
        && isValidVehicleType(request.resource.data.vehicleType);
      allow update: if isAdmin()
        && hasOnlyOverrideFields()
        && resource.data.name == request.resource.data.name
        && (
          (resource.data.origin in ["custom", "baseline"] && resource.data.origin == request.resource.data.origin)
          || (!("origin" in resource.data) && resource.data.source == "manual_override" && request.resource.data.origin == "custom")
        )
        && request.resource.data.origin in ["custom", "baseline"]
        && request.resource.data.active is bool
        && isValidVehicleType(request.resource.data.vehicleType);
      allow delete: if isAdmin();
    }

    match /vehicleModelOverrides/{id} {
      allow read: if isAllowedRole();
      allow create, update, delete: if false;
    }

    match /jobTypeOverrides/{id} {
      allow read: if isAllowedRole();
      allow create, update, delete: if false;
    }

    match /catalogSyncLocks/{target} {
      allow read: if isAllowedRole();
      allow create: if isAdmin();
      allow update: if isAdmin()
        && resource.data.lockedByEmail == request.auth.token.email
        && request.resource.data.lockedByEmail == request.auth.token.email
        && request.resource.data.target == resource.data.target
        && request.resource.data.jobId == resource.data.jobId;
      allow delete: if isAdmin() && resource.data.lockedByEmail == request.auth.token.email;
    }

    match /catalogSyncJobs/{jobId} {
      allow read: if isAllowedRole();
      allow create: if isAdmin();
      allow update: if isAdmin()
        && resource.data.actorEmail == request.auth.token.email
        && request.resource.data.actorEmail == resource.data.actorEmail
        && request.resource.data.target == resource.data.target
        && request.resource.data.mode == resource.data.mode
        && request.resource.data.policyVersion == resource.data.policyVersion
        && request.resource.data.createdAt == resource.data.createdAt;
      allow delete: if false;

      match /logs/{entryId} {
        allow read: if isAllowedRole();
        allow create: if isAdmin()
          && request.resource.data.jobId == jobId
          && request.resource.data.actorEmail == request.auth.token.email;
        allow update, delete: if false;
      }
    }

    match /syncErrors/{id} {
      allow read: if isAdmin();
      allow create: if isAllowedRole();
      allow update, delete: if isAdmin();
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
