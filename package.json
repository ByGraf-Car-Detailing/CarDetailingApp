    "type":  "commonjs",
    "bugs":  {
                 "url":  "https://github.com/ByGraf-Car-Detailing/CarDetailingApp/issues"
             },
    "homepage":  "https://github.com/ByGraf-Car-Detailing/CarDetailingApp#readme"
}

